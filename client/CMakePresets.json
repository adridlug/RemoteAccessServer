{
    "version": 5,
    "configurePresets": [
        {
            "name": "mingw-x64-debug",
            "displayName": "MinGW x64 Debug (vcpkg)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/mingw-x64-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET": "x64-mingw-static"
            }
        },
        {
            "name": "mingw-x64-release",
            "displayName": "MinGW x64 Release (vcpkg)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/mingw-x64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_TARGET_TRIPLET": "x64-mingw-static"
            }
        },
        {
            "name": "Custom configure preset",
            "displayName": "Custom configure preset",
            "description": "Sets Ninja generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-mingw-x64-debug",
            "configurePreset": "mingw-x64-debug"
        },
        {
            "name": "build-mingw-x64-release",
            "configurePreset": "mingw-x64-release"
        }
    ]
}